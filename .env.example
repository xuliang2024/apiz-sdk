# apiz SDK monorepo — example environment file.
# Copy to `.env.local` (already gitignored) and fill in your own values.
# NEVER commit real API keys.

# ---- Required for E2E tests ----
# Get yours at https://apiz.ai/#/v2/api-keys
APIZ_TEST_API_KEY=sk-replace-me-with-your-own-key

# ---- Optional ----
# Override the default base URL (defaults to https://api.apiz.ai).
# APIZ_BASE_URL=https://api.apiz.ai

# Override request timeout in milliseconds (JS) / seconds (Python/Go).
# APIZ_TIMEOUT=60000

# Log level for SDK debug output: silent | error | warn | info | debug
# APIZ_LOG_LEVEL=info
